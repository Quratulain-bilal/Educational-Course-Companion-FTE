# Local backend environment variables.
# Copy this file to `.env` and fill in real values locally.

DATABASE_URL="sqlite:///./course.db"
STORAGE_TYPE="local"
LOCAL_STORAGE_PATH="./local_content"

SECRET_KEY="change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

API_V1_STR="/api/v1"

GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"
GROQ_BASE_URL="https://api.groq.com/openai/v1"

# Optional legacy compatibility variable
GEMINI_API_KEY=""
